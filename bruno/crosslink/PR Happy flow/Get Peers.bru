meta {
  name: Get Peers
  type: http
  seq: 28
}

get {
  url: {{host}}/peers
  body: none
  auth: basic
}

headers {
  X-Okapi-Tenant: {{OkapiTenantReq}}
}

auth:basic {
  username: {{userName}}
  password: {{userPassword}}
}

vars:pre-request {
  prId: {{prId}}
}

settings {
  encodeUrl: true
  timeout: 0
}
