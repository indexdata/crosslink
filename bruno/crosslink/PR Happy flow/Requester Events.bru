meta {
  name: Requester Events
  type: http
  seq: 41
}

get {
  url: {{host}}/events?requester_req_id={{prId}}
  body: none
  auth: basic
}

params:query {
  requester_req_id: {{prId}}
}

headers {
  X-Okapi-User-Id: {{userName}}
  X-Okapi-Tenant: {{OkapiTenantReq}}
}

auth:basic {
  username: {{userName}}
  password: {{userPassword}}
}

settings {
  encodeUrl: true
  timeout: 0
}
