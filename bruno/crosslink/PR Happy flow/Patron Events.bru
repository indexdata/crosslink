meta {
  name: Patron Events
  type: http
  seq: 17
}

get {
  url: {{host}}/patron_requests/{{prId}}/events?side=borrowing&symbol={{requesterSymbol}}
  body: none
  auth: basic
}

params:query {
  side: borrowing
  symbol: {{requesterSymbol}}
}

headers {
  X-Okapi-Tenant: {{OkapiTenantReq}}
}

auth:basic {
  username: {{userName}}
  password: {{userPassword}}
}

vars:pre-request {
  prId: {{prId}}
}

settings {
  encodeUrl: true
  timeout: 0
}
