meta {
  name: Sup Patron Events
  type: http
  seq: 20
}

get {
  url: {{host}}/patron_requests/{{lendingPrId}}/events?side=lending
  body: none
  auth: basic
}

params:query {
  side: lending
}

headers {
  X-Okapi-Tenant: {{OkapiTenantSup}}
}

auth:basic {
  username: {{userName}}
  password: {{userPassword}}
}

vars:pre-request {
  prId: {{prId}}
}

settings {
  encodeUrl: true
  timeout: 0
}
