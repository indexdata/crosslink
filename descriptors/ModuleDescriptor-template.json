{
  "id": "directory-@version@",
  "name": "Directory",
  "provides": [
    {
      "id": "consortia",
      "version": "1.0",
      "handlers": [
        {
          "methods": [
            "GET"
          ],
          "pathPattern": "/consortia",
          "permissionsRequired": [
            "directory.consortia.collection.get"
          ]
        },
        {
          "methods": [
            "POST"
          ],
          "pathPattern": "/consortia",
          "permissionsRequired": [
            "directory.consortia.item.post"
          ]
        },
        {
          "methods": [
            "GET"
          ],
          "pathPattern": "/consortia/{id}",
          "permissionsRequired": [
            "directory.consortia.item.get"
          ]
        },
        {
          "methods": [
            "PATCH"
          ],
          "pathPattern": "/consortia/{id}",
          "permissionsRequired": [
            "directory.consortia.item.patch"
          ]
        },
        {
          "methods": [
            "DELETE"
          ],
          "pathPattern": "/consortia/{id}",
          "permissionsRequired": [
            "directory.consortia.item.delete"
          ]
        }
      ]
    },
    {
      "id": "entries",
      "version": "1.0",
      "handlers": [
        {
          "methods": [
            "GET"
          ],
          "pathPattern": "/entries",
          "permissionsRequired": [
            "directory.entries.collection.get"
          ]
        },
        {
          "methods": [
            "POST"
          ],
          "pathPattern": "/entries",
          "permissionsRequired": [
            "directory.entries.item.post"
          ]
        },
        {
          "methods": [
            "GET"
          ],
          "pathPattern": "/entries/{key}/{value}",
          "permissionsRequired": [
            "directory.entries.item.get"
          ]
        },
        {
          "methods": [
            "PATCH"
          ],
          "pathPattern": "/entries/{key}/{value}",
          "permissionsRequired": [
            "directory.entries.item.patch"
          ]
        },
        {
          "methods": [
            "DELETE"
          ],
          "pathPattern": "/entries/{key}/{value}",
          "permissionsRequired": [
            "directory.entries.item.delete"
          ]
        }
  ],
  "requires": [],
  "permissionSets": [
    {
      "description": "All direcotry consortial permissions ",
      "displayName": "Directory - all consortia permissions",
      "permissionName": "direcotry.consortia.all",
      "subPermissions": [
         "directory.consortia.collection.get",
         "directory.consortia.item.post",
         "directory.consortia.item.get",
         "directory.consortia.item.patch",
         "directory.consortia.item.delete"
      ],
      "visible": true
    },
    {
      "description": "All direcotry entry permissions ",
      "displayName": "Directory - all entry permissions",
      "permissionName": "direcotry.entries.all",
      "subPermissions": [
        "directory.entries.collection.get",
        "directory.entries.item.post",
        "directory.entries.item.get",
        "directory.entries.item.patch",
        "directory.entries.item.delete"
      ],
      "visible": true
    },
    {
      "description": "All directory module permissions",
      "displayName": "Directory - all permissions",
      "permissionName": "directory.all",
      "subPermissions": [
        "directory.consortia.all",
        "directory.entries.all",
      "visible": true
      ]
    }
  ]
}
