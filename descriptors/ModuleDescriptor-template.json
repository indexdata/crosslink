{
  "id": "directory-@version@",
  "name": "Directory",
  "provides": [
    {
      "id": "consortia",
      "version": "1.0",
      "handlers": [
        {
          "methods": ["GET"],
          "pathPattern": "/rsdir/consortia",
          "permissionsRequired": ["directory.consortia.collection.get"]
        },
        {
          "methods": ["POST"],
          "pathPattern": "/rsdir/consortia",
          "permissionsRequired": ["directory.consortia.item.post"]
        },
        {
          "methods": ["GET"],
          "pathPattern": "/rsdir/consortia/{id}",
          "permissionsRequired": ["directory.consortia.item.get"]
        },
        {
          "methods": ["PATCH"],
          "pathPattern": "/rsdir/consortia/{id}",
          "permissionsRequired": ["directory.consortia.item.patch"]
        },
        {
          "methods": ["DELETE"],
          "pathPattern": "/rsdir/consortia/{id}",
          "permissionsRequired": ["directory.consortia.item.delete"]
        }
      ]
    },
    {
      "id": "entries",
      "version": "1.0",
      "handlers": [
        {
          "methods": ["GET"],
          "pathPattern": "/rsdir/entries",
          "permissionsRequired": ["directory.entries.collection.get"]
        },
        {
          "methods": ["POST"],
          "pathPattern": "/rsdir/entries",
          "permissionsRequired": ["directory.entries.item.post"]
        },
        {
          "methods": ["GET"],
          "pathPattern": "/rsdir/entries/{key}/{value}",
          "permissionsRequired": ["directory.entries.item.get"]
        },
        {
          "methods": ["PATCH"],
          "pathPattern": "/rsdir/entries/{key}/{value}",
          "permissionsRequired": ["directory.entries.item.patch"]
        },
        {
          "methods": ["DELETE"],
          "pathPattern": "/rsdir/entries/{key}/{value}",
          "permissionsRequired": ["directory.entries.item.delete"]
        }
      ]
    }
  ],
  "requires": [],
  "permissionSets": [
    {
      "description": "All directory consortia permissions",
      "displayName": "Directory - all consortia permissions",
      "permissionName": "directory.consortia.all",
      "subPermissions": [
        "directory.consortia.collection.get",
        "directory.consortia.item.post",
        "directory.consortia.item.get",
        "directory.consortia.item.patch",
        "directory.consortia.item.delete"
      ],
      "visible": true
    },
    {
      "description": "All directory entry permissions",
      "displayName": "Directory - all entry permissions",
      "permissionName": "directory.entries.all",
      "subPermissions": [
        "directory.entries.collection.get",
        "directory.entries.item.post",
        "directory.entries.item.get",
        "directory.entries.item.patch",
        "directory.entries.item.delete"
      ],
      "visible": true
    },
    {
      "description": "All directory module permissions",
      "displayName": "Directory - all permissions",
      "permissionName": "directory.all",
      "subPermissions": [
        "directory.consortia.all",
        "directory.entries.all"
      ],
      "visible": true
    }
  ]
}
